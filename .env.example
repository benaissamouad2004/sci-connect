# SciConnect — Variables d'environnement (exemple)
# Copier ce fichier en .env et remplir les valeurs

# ─── Google OAuth ───
# Obtenir sur https://console.cloud.google.com → APIs & Services → Credentials
# Ajouter les origines autorisées : http://localhost:5000 ET https://votre-domaine.com
GOOGLE_CLIENT_ID=REMPLACER_PAR_TON_CLIENT_ID.apps.googleusercontent.com

# ─── Clé secrète Flask (générer une chaîne aléatoire longue) ───
SECRET_KEY=changer-en-production-avec-une-cle-longue

# ─── URL publique de l'application ───
# Localhost pour développement — utiliser l'URL HTTPS en production
APP_URL=http://localhost:5000
# APP_URL=https://votre-domaine.com

# ─── Base de données ───
# DATABASE_URL=sqlite:///sciconnect.db

# ─── Email — Production (Gmail avec mot de passe d'application) ───
# 1. Activer la validation 2 étapes sur le compte Gmail
# 2. Aller sur myaccount.google.com → Sécurité → Mots de passe d'application
# 3. Créer un mot de passe d'application "SciConnect"
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ton-email@gmail.com
MAIL_PASSWORD=mot-de-passe-application-16-caracteres

# ─── Email — Développement (Mailtrap — test sans vrai envoi) ───
# USE_MAILTRAP=true
# MAILTRAP_USERNAME=ton-username-mailtrap
# MAILTRAP_PASSWORD=ton-password-mailtrap
# MAILTRAP_SERVER=sandbox.smtp.mailtrap.io
# MAILTRAP_PORT=2525